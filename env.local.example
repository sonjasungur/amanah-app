# Copy to .env.local for Postgres + API mode (do NOT commit .env.local)
# cp env.local.example .env.local

DATABASE_URL=postgresql://amanah:amanah_dev_password@localhost:5436/amanah_dev
AMANAH_SERVER_STORAGE=postgres
NEXT_PUBLIC_AUTH_MODE=api
NEXT_PUBLIC_STORAGE_MODE=api
SESSION_SECRET=change-me-local-only
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI — rules works without API key; openai requires OPENAI_API_KEY + user consent in UI
AMANAH_AI_PROVIDER=rules
AMANAH_AI_ENABLED=true
# AMANAH_AI_PROVIDER=openai
# OPENAI_API_KEY=
