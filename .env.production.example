# AmanahOrdner — Production environment (copy to .env.production on server)
# NEVER commit .env.production with real secrets.

NODE_ENV=production

# --- Public site ---
NEXT_PUBLIC_SITE_URL=https://amanah.example.com
NEXT_PUBLIC_APP_URL=https://amanah.example.com

# --- Auth & storage (production defaults) ---
NEXT_PUBLIC_AUTH_MODE=api
NEXT_PUBLIC_STORAGE_MODE=api
AMANAH_SERVER_STORAGE=postgres

# --- Postgres (used by docker-compose.prod.yml) ---
POSTGRES_USER=amanah
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
POSTGRES_DB=amanah
# Internal Docker URL (compose overrides host for app service):
DATABASE_URL=postgresql://amanah:REPLACE_WITH_STRONG_DB_PASSWORD@postgres:5432/amanah?schema=public

# --- Session (min. 32 random characters) ---
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
AUTH_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS

# --- Knowledge retrieval ---
AMANAH_KNOWLEDGE_RETRIEVAL=keyword
AMANAH_EMBEDDING_PROVIDER=none
AMANAH_EMBEDDING_MODEL=
AMANAH_KNOWLEDGE_TOP_K=3

# --- AI (rules = safe/cost-free default; openai optional) ---
AMANAH_AI_ENABLED=true
AMANAH_AI_PROVIDER=rules
AMANAH_AI_MODEL_FAST=
AMANAH_AI_MODEL_SMART=
AI_PROVIDER=rules

# OpenAI — optional, server-side only, requires user consent in UI
# OPENAI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=
