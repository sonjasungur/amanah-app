*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_ed25519
*.credentials.csv
*credentials*.csv
*credential*.json
*service-account*.json
*secrets*.json
*secret*.txt

# Database dumps / local backups
*.sql.gz
*.dump
*.bak
*.backup
*.backup.*
