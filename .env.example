# AmanahOrdner — Environment Variables

# AI Provider: "mock" (default) or "openai"
AI_PROVIDER=mock

# OpenAI (only needed when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App URL (for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth mode: "local" (default, browser-only demo) or "api" (server sessions)
NEXT_PUBLIC_AUTH_MODE=local

# Storage mode: "local" (default, LocalStorage) or "api" (server via /api/amanah)
NEXT_PUBLIC_STORAGE_MODE=local

# Server auth secret (for future JWT/session signing — change in production)
AUTH_SECRET=change-me-in-production

# Postgres (optional — start with docker compose -f docker-compose.local.yml up -d)
# DATABASE_URL=postgresql://amanah:amanah_dev@localhost:5432/amanah
DATABASE_URL=
