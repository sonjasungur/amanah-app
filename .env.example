# AmanahOrdner — Environment Variables

# --- AI Companion (Phase 3A) ---
# Provider: rules (default, free), mock (tests/dev), openai (optional, server-side only)
AMANAH_AI_PROVIDER=rules
AMANAH_AI_ENABLED=true
AMANAH_AI_MODEL_FAST=
AMANAH_AI_MODEL_SMART=

# Legacy aliases (still supported)
AI_PROVIDER=rules

# OpenAI — server-side only, never expose in frontend
OPENAI_API_KEY=
OPENAI_MODEL=

# App URL (for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth mode: "local" (default, browser-only demo) or "api" (server sessions)
NEXT_PUBLIC_AUTH_MODE=local

# Storage mode: "local" (default, LocalStorage) or "api" (server via /api/amanah)
NEXT_PUBLIC_STORAGE_MODE=local

# Server storage backend: "memory" (default) or "postgres" (requires DATABASE_URL)
AMANAH_SERVER_STORAGE=memory

# Session signing secret (change in production — never commit real secrets)
SESSION_SECRET=change-me-local-only
AUTH_SECRET=change-me-in-production

# Postgres (optional — start with docker compose -f docker-compose.local.yml up -d postgres)
# Then run: npm run db:migrate
# DATABASE_URL=postgresql://amanah:amanah_dev_password@localhost:5436/amanah_dev
DATABASE_URL=

# --- API + Postgres local dev (copy to .env.local, do not commit) ---
# DATABASE_URL=postgresql://amanah:amanah_dev_password@localhost:5436/amanah_dev
# AMANAH_SERVER_STORAGE=postgres
# NEXT_PUBLIC_AUTH_MODE=api
# NEXT_PUBLIC_STORAGE_MODE=api
# SESSION_SECRET=change-me-local-only
# AMANAH_AI_PROVIDER=rules
